import tkinter as tk
from tkinter import messagebox
import random

def generate_plan():
    goals = goal_entry.get()
    if not goals:
        messagebox.showwarning("Input Error", "Please enter your goals!")
        return

    goal_list = [goal.strip() for goal in goals.split(",")]

    # Get hours per day
    try:
        hours_per_day = float(hours_entry.get())
    except:
        hours_per_day = 2

    # Assign random difficulty
    goal_difficulty = {}
    for goal in goal_list:
        goal_difficulty[goal] = random.randint(1, 5)

    # Create weekly plan
    days = ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"]
    weekly_plan = {day: [] for day in days}

    for goal, diff in goal_difficulty.items():
        sessions = max(1, int((diff/5)*7))
        chosen_days = random.sample(days, sessions)
        for day in chosen_days:
            weekly_plan[day].append(goal)

    # Display output
    output_text.delete(1.0, tk.END)
    output_text.insert(tk.END, "Your Weekly Plan:\n\n")

    for day in days:
        tasks = weekly_plan[day]
        if tasks:
            output_text.insert(tk.END, f"{day}: {', '.join(tasks)}\n")
        else:
            output_text.insert(tk.END, f"{day}: Rest / Catch up\n")

    # Tips
    output_text.insert(tk.END, "\nTips:\n")
    for goal, diff in goal_difficulty.items():
        if diff >= 4:
            tip = "Hard – break into smaller parts"
        elif diff == 3:
            tip = "Medium – stay consistent"
        else:
            tip = "Easy – keep going"
        output_text.insert(tk.END, f"- {goal.capitalize()}: {tip}\n")


# GUI Setup
root = tk.Tk()
root.title("AI Life Goal Planner")
root.geometry("500x500")

# Title
title = tk.Label(root, text="AI Life Goal Planner", font=("Arial", 16, "bold"))
title.pack(pady=10)

# Goals input
goal_label = tk.Label(root, text="Enter goals (comma separated):")
goal_label.pack()
goal_entry = tk.Entry(root, width=50)
goal_entry.pack(pady=5)

# Hours input
hours_label = tk.Label(root, text="Hours per day:")
hours_label.pack()
hours_entry = tk.Entry(root, width=20)
hours_entry.pack(pady=5)

# Button
generate_btn = tk.Button(root, text="Generate Plan", command=generate_plan)
generate_btn.pack(pady=10)

# Output box
output_text = tk.Text(root, height=15, width=60)
output_text.pack(pady=10)

# Run app
root.mainloop()